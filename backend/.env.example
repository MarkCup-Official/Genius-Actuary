APP_ENV=development
APP_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
SESSION_DB_PATH=

# Adapter selection: mock | openai_compatible
ANALYSIS_ADAPTER=openai_compatible
ANALYSIS_PROVIDER=minimax
ANALYSIS_REGION=cn
ANALYSIS_API_BASE_URL=
ANALYSIS_API_KEY=
ANALYSIS_MODEL=MiniMax-M2.5
ANALYSIS_TIMEOUT_SECONDS=30
ANALYSIS_RETRY_ATTEMPTS=3
CLARIFICATION_FOLLOW_UP_ROUND_LIMIT=10

SEARCH_ADAPTER=brave
SEARCH_API_BASE_URL=https://api.search.brave.com/res/v1/web/search
SEARCH_API_KEY=
SEARCH_COUNTRY=CN
SEARCH_LANGUAGE=zh-hans
SEARCH_UI_LANGUAGE=zh-CN
SEARCH_RESULT_COUNT=5
SEARCH_EXTRA_SNIPPETS=true

CHART_ADAPTER=disabled
CALCULATION_MCP_ENABLED=false

DEBUG_USERNAME=debug-admin
DEBUG_PASSWORD=change-me-debug-password
